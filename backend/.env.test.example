# backend/.env.test
#
# Environment overrides for tests. Copy and fill in real values.
# This file takes precedence over .env when running tests.
#
# IMPORTANT: Keep your CLERK_SECRET_KEY for a *development* Clerk instance.
# Creating sessions programmatically (required for tests) only works in dev mode.
#
# Usage:
#   cp backend/.env.test.example backend/.env.test
#   # fill in the values below
#   cd backend && pytest

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/applitrack_test
CLERK_SECRET_KEY=sk_test_YOUR_DEVELOPMENT_SECRET_KEY_HERE
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
ENVIRONMENT=testing
